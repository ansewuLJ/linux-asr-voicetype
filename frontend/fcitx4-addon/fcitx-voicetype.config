[VoiceType]
# ASR Host
# 需要与UI配置完全相同。通常保持 127.0.0.1。
#Host=127.0.0.1
# ASR Port
# 需要与UI配置完全相同。
#Port=8789
# Hold-To-Talk Key
# 按住开始录音，松开结束并上屏。
#HoldKey=ALT_R
# Modifier Hold Key
# 单修饰键按住录音；设置后优先于 HoldKey。可选:
# DISABLED, ALT_R, ALT_L, CTRL_R, CTRL_L, SHIFT_R, SHIFT_L
#HoldModifier=DISABLED
# Toggle Recording Key
# 按一次开始，再按一次结束并上屏。默认关闭，可按需设置。
#ToggleKey=
